import {StackElementData} from "managers.StacksManager.StackElementData"

export class ChapterData extends StackElementData
{
    constructor({
        isSelected,
        id,
        element,
        elementInfo,
        parentDataIds,
        isInsideBible       = true,
        isInsideBook        = true,
        isActive            = false,
        isHidden            = false
    })
    {
        super({id, element, elementInfo, parentDataIds, isInsideBible, isHidden});
        this.isInsideBook       = isInsideBook;
        this.isActive           = isActive;
        this.HighlightsInfo     = [];
        this.isSelected = isSelected;
    }
    AddChild(){}
    
    ResetData()
    {
        this.element                = null;
        this.isInsideBible          = null;
        this.isInsideBook           = null;
        this.isActive               = false;
    }

    AddHighlightInfo(newHighlightInfo)
    {
        this.HighlightsInfo.push(newHighlightInfo)
    }

    GetHighlightInfoByKey(key)
    {
        return this.HighlightsInfo.find((highlightInfo) => {return highlightInfo.key == key});
    }
}