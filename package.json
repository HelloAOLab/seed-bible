{
  "name": "seed-bible",
  "version": "1.1.0",
  "description": "The source code behind the Seed Bible.",
  "type": "module",
  "main": "server/dist/index.js",
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest watch",
    "dev": "bun server/index.ts",
    "build": "pnpm build:client && pnpm build:ssr && pnpm build:server",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr standalone/entry-ssr.tsx",
    "build:server": "bun build --target=bun --external express --external vite --outfile=server/dist/index.js ./server/index.ts",
    "lint": "eslint packages",
    "lint:fix": "eslint packages --fix",
    "check:ts": "pnpm run check:ts:client && pnpm run check:patterns",
    "check:ts:client": "tsc-silent --project ./tsconfig.json --suppressConfig ./tsc-silent.config.cjs",
    "check:patterns": "tsc --project ./patterns/tsconfig.json",
    "pattern": "tsx script/pattern.ts",
    "notify": "tsx script/notify.ts",
    "build-size-report": "tsx script/build-size-report.ts",
    "i18n": "tsx script/i18n.ts",
    "list-bible-translations": "tsx script/list-bible-translations.ts",
    "format": "prettier --write \"packages/**/*.{js,jsx,ts,tsx,css}\"",
    "format:changed": "pretty-quick",
    "prepare": "husky && tsx script/setupMergeDriver.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HelloAOLab/seed-bible.git"
  },
  "keywords": [
    "bible"
  ],
  "author": "AO Lab <hello@helloao.org>",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/HelloAOLab/seed-bible/issues"
  },
  "homepage": "https://github.com/HelloAOLab/seed-bible#readme",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.15.0",
    "bun": ">=1.3.14"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.27.1",
    "@casual-simulation/aux-common": "^4.2.3",
    "@casual-simulation/aux-records": "^4.2.3",
    "@casual-simulation/aux-runtime": "^4.2.3",
    "@casual-simulation/aux-vm": "^4.2.3",
    "@casual-simulation/crypto": "^4.0.5",
    "@casual-simulation/fast-json-stable-stringify": "^4.0.5",
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.32.0",
    "@eslint/json": "^1.2.0",
    "@google-cloud/translate": "^9.3.0",
    "@jest/environment": "^30.3.0",
    "@preact/preset-vite": "^2.10.5",
    "@preact/signals": "^2.9.1",
    "@preact/signals-debug": "^1.4.2",
    "@testing-library/preact": "^3.2.4",
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/luxon": "^3.7.2",
    "@types/node": "^24.5.2",
    "@types/opentype.js": "^1.3.9",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/utils": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.2",
    "axios": "catalog:",
    "babel-jest": "^30.1.2",
    "casualos": "4.2.4-alpha.25223847785",
    "chokidar": "^5.0.0",
    "commander": "^14.0.1",
    "conf": "^15.0.2",
    "es-toolkit": "1.39.10",
    "esbuild": "^0.25.10",
    "eslint": "^9.32.0",
    "express": "^5.2.1",
    "globals": "^16.3.0",
    "hash.js": "^1.1.7",
    "html-entities": "2.6.0",
    "husky": "^9.1.7",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.3.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "preact": "catalog:",
    "preact-iso": "catalog:",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "prompts": "^2.4.2",
    "puppeteer": "^24.30.0",
    "rxjs": "catalog:",
    "ts-jest": "^29.4.6",
    "ts-morph": "^27.0.2",
    "tsc-silent": "1.2.2",
    "tsx": "^4.20.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.38.0",
    "uuid": "catalog:",
    "vite": "^8.0.13",
    "vite-bundle-analyzer": "^1.3.8",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "bowser": "^2.14.1",
    "debounce": "^2.2.0",
    "get-tsconfig": "^4.13.0",
    "html2canvas": "^1.4.1",
    "i18next": "catalog:",
    "i18next-resources-to-backend": "catalog:",
    "imagetracerjs": "^1.2.6",
    "opentype.js": "^1.3.4",
    "preact-render-to-string": "catalog:",
    "prompts": "^2.4.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typesense": "catalog:",
    "zod": "catalog:",
    "luxon": "catalog:"
  }
}
